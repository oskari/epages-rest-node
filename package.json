{
  "name": "epages-rest-node",
  "version": "1.1.0",
  "description": "TypeScript/Node.js SDK (ESM) for the ePages Now REST API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oskari/epages-rest-node.git"
  },
  "homepage": "https://github.com/oskari/epages-rest-node#readme",
  "bugs": {
    "url": "https://github.com/oskari/epages-rest-node/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && cp -r src/generated dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "example": "node examples/usage.mjs",
    "generate:openapi": "node scripts/generate-openapi.cjs && node scripts/generate-schemas-from-examples.cjs && node scripts/inject-schemas.cjs",
    "generate:types": "openapi-typescript openapi/api.yaml -o src/generated/api.d.ts",
    "generate:api": "npm run generate:openapi && npm run generate:types",
    "release": "node scripts/release.cjs",
    "release:patch": "node scripts/release.cjs patch",
    "release:minor": "node scripts/release.cjs minor",
    "release:major": "node scripts/release.cjs major",
    "release:retag": "node scripts/retag.cjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.10.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "webapi-parser": "^0.5.0"
  },
  "overrides": {
    "ajv": "^8.12.0"
  }
}
